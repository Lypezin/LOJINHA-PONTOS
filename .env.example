# Runtime da aplicação/Vercel: pooler transacional do Supabase (porta 6543).
DATABASE_URL=postgresql://postgres.SEU_PROJECT_REF:SUA_SENHA@SEU_POOLER.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1&pool_timeout=20

# Prisma Migrate, seed e ferramentas locais: pooler de sessão (porta 5432).
DIRECT_URL=postgresql://postgres.SEU_PROJECT_REF:SUA_SENHA@SEU_POOLER.supabase.com:5432/postgres?sslmode=require

# URL pública usada nos links de recuperação de senha.
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
SESSION_DURATION_DAYS=30
AUTH_AUDIT_SALT=troque-por-um-segredo-longo-e-aleatorio
TRUST_PROXY=false

# Primeiro acesso administrativo criado por `npm run db:seed`.
ADMIN_EMAIL=admin@lojinha.local
ADMIN_PASSWORD=TroqueAgora#2026
ROTATE_ADMIN_PASSWORD=false

# E-mail transacional (opcional no desenvolvimento, obrigatório em produção).
RESEND_API_KEY=
EMAIL_FROM=Lojinha EntreGo <nao-responda@seudominio.com.br>

# Dados de demonstração para validar os fluxos localmente.
SEED_DEMO_DATA=false
